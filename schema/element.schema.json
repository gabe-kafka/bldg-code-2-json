{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bldg-code-element",
  "title": "Building Code Element",
  "description": "A single extractable element from a building code PDF",
  "type": "object",
  "required": ["id", "type", "source", "title", "data", "metadata"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique element ID, e.g. ASCE7-22-26.5-T1",
      "pattern": "^[A-Z0-9]+-[0-9.]+-[A-Z]?[0-9.]+(-[A-Za-z0-9]+)?$"
    },
    "type": {
      "type": "string",
      "enum": ["table", "provision", "formula", "figure", "reference"]
    },
    "source": {
      "type": "object",
      "required": ["standard", "chapter", "section"],
      "properties": {
        "standard": { "type": "string" },
        "chapter": { "type": "integer" },
        "section": { "type": "string" },
        "page": { "type": ["integer", "null"] }
      }
    },
    "title": { "type": "string" },
    "description": { "type": ["string", "null"] },
    "data": {
      "oneOf": [
        { "$ref": "#/$defs/table_data" },
        { "$ref": "#/$defs/figure_data" },
        { "$ref": "#/$defs/formula_data" },
        { "$ref": "#/$defs/provision_data" },
        { "$ref": "#/$defs/reference_data" }
      ]
    },
    "cross_references": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metadata": {
      "type": "object",
      "required": ["extracted_by", "qc_status"],
      "properties": {
        "extracted_by": {
          "type": "string",
          "enum": ["auto", "manual"]
        },
        "qc_status": {
          "type": "string",
          "enum": ["pending", "passed", "failed"]
        },
        "qc_notes": { "type": ["string", "null"] }
      }
    }
  },
  "$defs": {
    "table_data": {
      "type": "object",
      "required": ["columns", "rows"],
      "properties": {
        "columns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "unit": { "type": ["string", "null"] }
            }
          }
        },
        "rows": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "figure_data": {
      "type": "object",
      "required": ["figure_class", "data"],
      "properties": {
        "figure_class": {
          "type": "object",
          "required": ["figure_type"],
          "properties": {
            "figure_type": {
              "type": "string",
              "enum": ["xy_chart", "diagram", "multi_panel", "contour_map", "table_image"]
            },
            "confidence": { "type": "number" },
            "description": { "type": "string" },
            "complexity": { "type": "string", "enum": ["low", "medium", "high"] }
          }
        },
        "data": {
          "oneOf": [
            { "$ref": "#/$defs/xy_chart_data" },
            { "$ref": "#/$defs/diagram_data" },
            { "$ref": "#/$defs/multi_panel_data" },
            { "$ref": "#/$defs/contour_map_data" },
            { "$ref": "#/$defs/table_data" }
          ]
        },
        "verification": {
          "type": "object",
          "properties": {
            "verified": { "type": "boolean" },
            "issues": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "severity": { "type": "string", "enum": ["critical", "warning"] },
                  "description": { "type": "string" },
                  "fix": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "xy_chart_data": {
      "type": "object",
      "required": ["x_axis", "y_axis", "curves"],
      "properties": {
        "x_axis": { "$ref": "#/$defs/axis" },
        "y_axis": { "$ref": "#/$defs/axis" },
        "curves": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "points", "interpolation"],
            "properties": {
              "label": { "type": "string" },
              "points": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 2,
                  "maxItems": 2
                },
                "minItems": 5
              },
              "interpolation": {
                "type": "string",
                "enum": ["linear", "linear_on_log_x", "step", "cubic"]
              }
            }
          }
        }
      }
    },
    "diagram_data": {
      "type": "object",
      "required": ["diagram_type", "elements"],
      "properties": {
        "diagram_type": {
          "type": "string",
          "enum": ["pressure_zones", "topo_feature", "building_geometry", "roof_zones", "wall_zones", "wind_direction", "other"]
        },
        "elements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "type", "description"],
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["zone", "dimension", "annotation", "arrow", "boundary", "surface", "angle"] },
              "description": { "type": "string" },
              "value": {},
              "unit": { "type": ["string", "null"] },
              "position": { "type": ["string", "null"] },
              "conditions": { "type": ["string", "null"] }
            }
          }
        },
        "relationships": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to", "type"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "type": { "type": "string", "enum": ["defines", "bounds", "equals", "references"] },
              "description": { "type": "string" }
            }
          }
        },
        "geometry": {
          "type": "object",
          "properties": {
            "description": { "type": "string" },
            "key_dimensions": { "type": "object" },
            "coordinate_system": { "type": "string" }
          }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "multi_panel_data": {
      "type": "object",
      "required": ["panels"],
      "properties": {
        "panels": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["panel_id", "panel_type", "data"],
            "properties": {
              "panel_id": { "type": "string" },
              "title": { "type": ["string", "null"] },
              "panel_type": { "type": "string", "enum": ["xy_chart", "diagram", "table_image"] },
              "data": { "type": "object" }
            }
          }
        },
        "shared_context": { "type": ["string", "null"] }
      }
    },
    "contour_map_data": {
      "type": "object",
      "required": ["map_type", "value_name", "value_unit", "contours"],
      "properties": {
        "map_type": { "type": "string", "enum": ["wind_speed", "snow_load", "rain", "other"] },
        "value_name": { "type": "string" },
        "value_unit": { "type": "string" },
        "risk_category": { "type": ["string", "null"] },
        "return_period": { "type": ["string", "null"] },
        "contours": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["value"],
            "properties": {
              "value": { "type": "number" },
              "description": { "type": "string" }
            }
          }
        },
        "special_regions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "value": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "formula_data": {
      "type": "object",
      "required": ["expression", "parameters"],
      "properties": {
        "expression": { "type": "string" },
        "parameters": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "unit": { "type": "string" },
              "range": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 2,
                "maxItems": 2
              },
              "source": { "type": "string" }
            }
          }
        },
        "samples": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2
            }
          }
        }
      }
    },
    "provision_data": {
      "type": "object",
      "required": ["rule", "conditions"],
      "properties": {
        "rule": { "type": "string" },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["parameter", "operator", "value"],
            "properties": {
              "parameter": { "type": "string" },
              "operator": {
                "type": "string",
                "enum": ["==", "!=", ">", ">=", "<", "<=", "in", "not_in"]
              },
              "value": {},
              "unit": { "type": ["string", "null"] }
            }
          }
        },
        "then": { "type": "string" },
        "else": { "type": ["string", "null"] },
        "exceptions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "reference_data": {
      "type": "object",
      "required": ["target"],
      "properties": {
        "target": { "type": "string" },
        "url": { "type": "string" },
        "parameters": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "axis": {
      "type": "object",
      "required": ["name", "unit", "scale"],
      "properties": {
        "name": { "type": "string" },
        "unit": { "type": "string" },
        "scale": {
          "type": "string",
          "enum": ["linear", "log"]
        }
      }
    }
  }
}
